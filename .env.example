# .env.local — copy this to .env.local and fill in your values
# Do NOT commit the actual .env.local file to git

# PostgreSQL connection string (must support pgvector extension)
# Use Neon (neon.tech) — it supports pgvector out of the box
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Google Gemini API key — FREE at aistudio.google.com
# 1. Go to aistudio.google.com
# 2. Click "Get API Key" → "Create API Key"
# 3. Copy and paste it here
GEMINI_API_KEY="AIza..."

# JWT Secret — used to sign session tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-random-secret-here"
